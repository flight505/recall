{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "_comment": "Inject recalled memories on every session event — ensures context persists after compaction or resume",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd' session-start.sh",
            "timeout": 5000,
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "_comment": "Capture session summary on exit — async to never block user",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd' stop.sh",
            "timeout": 30000,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "_comment": "Save working state before context compaction — sync so it completes before compaction",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd' pre-compact.sh",
            "timeout": 30000,
            "async": false
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "_comment": "Log compaction event to episodic memory",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd' post-compact.sh",
            "timeout": 5000,
            "async": false
          }
        ]
      }
    ]
  }
}
